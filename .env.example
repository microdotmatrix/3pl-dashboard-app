DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require"

# Better Auth — required in production. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Public base URL used for invite links and password reset emails.
BETTER_AUTH_URL="http://localhost:3000"

# Email of the primary admin. The first account that signs up with this
# email is auto-approved and promoted to role="admin".
ADMIN_EMAIL=""

# ShipStation V2 API keys — one per client brand. Generate at
# Settings > Account > API Settings > Generate API key in each account.
SHIPSTATION_API_KEY_DIP=""
SHIPSTATION_API_KEY_FATASS=""
SHIPSTATION_API_KEY_RYOT=""

# Bearer token required by POST /api/cron/shipstation. Generate with:
#   openssl rand -hex 32
CRON_SECRET=""

# Monday.com API token (Admin > Developers > My access tokens). Used to fetch
# the shared package-cost board for billing rate lookups.
MONDAY_API_TOKEN=""

# Numeric board ID for the shared package list (open the board on monday.com
# and copy the trailing number from the URL).
MONDAY_PACKAGE_BOARD_ID=""

# Membrane workspace credentials. From the Membrane workspace settings.
# Used to mint short-lived JWTs that authenticate the SDK.
MEMBRANE_WORKSPACE_KEY=""
MEMBRANE_WORKSPACE_SECRET=""

# Membrane connection ID for the Zoho Books connection in this workspace.
MEMBRANE_ZOHO_CONNECTION_ID=""

# OpenRouter API key for the billing assistant agent.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=""
